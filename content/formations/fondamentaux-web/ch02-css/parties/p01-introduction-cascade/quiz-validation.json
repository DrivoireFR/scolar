  "questions": [
    {
      "id": "q1",
      "type": "single",
      "prompt": "Quel mode d’application du CSS est le plus maintenable pour un site complet ?",
      "choices": [
        { "id": "a", "label": "Feuille de style externe liée avec <link rel=\"stylesheet\">" },
        { "id": "b", "label": "Uniquement des attributs style=\"\" sur chaque balise" },
        { "id": "c", "label": "Un seul fichier JSON sans CSS" },
        { "id": "d", "label": "Des commentaires HTML uniquement" }
      ],
      "correctChoiceIds": ["a"],
      "points": 1,
      "feedback": { "correct": "Externe = réutilisation et cache.", "incorrect": "Inline ne scale pas." }
    },
    {
      "id": "q2",
      "type": "single",
      "prompt": "Une règle CSS se compose d’un…",
      "choices": [
        { "id": "a", "label": "Sélecteur puis un bloc { propriété: valeur; }" },
        { "id": "b", "label": "DOCTYPE puis un script" },
        { "id": "c", "label": "Attribut href seul" },
        { "id": "d", "label": "Élément <rule> en HTML5" }
      ],
      "correctChoiceIds": ["a"],
      "points": 1,
      "feedback": { "correct": "Syntaxe sélecteur + déclarations.", "incorrect": "Pas de balise rule native." }
    },
    {
      "id": "q3",
      "type": "single",
      "prompt": "À spécificité égale, quelle règle l’emporte en général ?",
      "choices": [
        { "id": "a", "label": "La dernière déclarée dans l’ordre du code" },
        { "id": "b", "label": "Toujours la première" },
        { "id": "c", "label": "Celle avec le sélecteur le plus court en caractères" },
        { "id": "d", "label": "Aucune : le navigateur choisit au hasard" }
      ],
      "correctChoiceIds": ["a"],
      "points": 1,
      "feedback": { "correct": "Ordre source compte à égalité.", "incorrect": "La cascade n’est pas aléatoire." }
    },
