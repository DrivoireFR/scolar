      "id": "q1",
      "type": "single",
      "prompt": "Combien de niveaux de titres HTML existe-t-il et quel est l’usage recommandé pour `h1` ?",
      "choices": [
        { "id": "a", "label": "6 niveaux (`h1`–`h6`) ; un seul `h1` principal par page en général" },
        { "id": "b", "label": "3 niveaux ; autant de `h1` que de sections" },
        { "id": "c", "label": "10 niveaux ; `h1` réservé au pied de page" },
        { "id": "d", "label": "1 niveau ; `h1` interdit" }
      ],
      "correctChoiceIds": ["a"],
      "points": 1,
      "feedback": { "correct": "Oui : six niveaux et hiérarchie logique.", "incorrect": "Il y a six niveaux de titres en HTML." }
    },
    {
      "id": "q2",
      "type": "single",
      "prompt": "Quelle balise représente typiquement un paragraphe de texte courant ?",
      "choices": [
        { "id": "a", "label": "<p>" },
        { "id": "b", "label": "<br>" },
        { "id": "c", "label": "<hr>" },
        { "id": "d", "label": "<span>" }
