      "type": "single",
      "prompt": "À quoi sert principalement `<br>` ?",
      "choices": [
        { "id": "a", "label": "Forcer un saut de ligne à l’intérieur d’un bloc de texte" },
        { "id": "b", "label": "Créer une bordure entre deux colonnes CSS" },
