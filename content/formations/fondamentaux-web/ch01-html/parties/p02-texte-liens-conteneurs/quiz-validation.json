        { "id": "d", "label": "Insérer une image" }
      ],
      "correctChoiceIds": ["a"],
      "points": 1,
      "feedback": { "correct": "`<br>` = line break.", "incorrect": "Ne confonds pas avec `<hr>` ou les titres." }
    },
    {
