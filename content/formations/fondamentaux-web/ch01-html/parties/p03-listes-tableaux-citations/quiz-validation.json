  "questions": [
    {
      "id": "q1",
      "type": "single",
      "prompt": "Quelle balise pour une liste à puces sans ordre imposé ?",
      "choices": [
        { "id": "a", "label": "<ul>" },
        { "id": "b", "label": "<ol>" },
        { "id": "c", "label": "<dl>" },
        { "id": "d", "label": "<table>" }
      ],
      "correctChoiceIds": ["a"],
      "points": 1,
      "feedback": { "correct": "unordered list = ul", "incorrect": "ol = ordonnée." }
    },
    {
      "id": "q2",
      "type": "single",
      "prompt": "Quelle balise pour une liste dont l’ordre des éléments a du sens ?",
      "choices": [
        { "id": "a", "label": "<ol>" },
        { "id": "b", "label": "<ul>" },
        { "id": "c", "label": "<blockquote>" },
        { "id": "d", "label": "<nav>" }
