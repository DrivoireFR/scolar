        { "id": "c", "label": "Un tableau de données" },
        { "id": "d", "label": "Un script JavaScript" }
      ],
      "correctChoiceIds": ["a"],
      "points": 1,
      "feedback": { "correct": "Contact, pas géolocalisation arbitraire.", "incorrect": "Usage sémantique limité." }
