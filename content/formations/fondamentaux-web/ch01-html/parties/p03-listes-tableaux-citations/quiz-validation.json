        { "id": "a", "label": "<dd>" },
        { "id": "b", "label": "<dt>" },
        { "id": "c", "label": "<q>" },
        { "id": "d", "label": "<abbr>" }
      ],
      "correctChoiceIds": ["a"],
      "points": 1,
      "feedback": { "correct": "definition description", "incorrect": "Ne confonds pas dt/dd." }
    },
    {
